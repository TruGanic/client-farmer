# Expo only exposes EXPO_PUBLIC_* to the app. Use these names in .env.

# Gateway base URL (no trailing slash)
EXPO_PUBLIC_GATEWAY_URL=http://129.212.238.68:3000

# Client DID and private key (hex, no 0x prefix)
EXPO_PUBLIC_CLIENT_DID=did:web:truganic.github.io:did-documents:clients:farmer-client
EXPO_PUBLIC_CLIENT_PRIVATE_KEY=your_hex_private_key_here
